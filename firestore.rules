rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
  
    // FUNGSI BANTUAN (HELPER FUNCTIONS)
    // Mengecek apakah user sudah login
    function isAuthenticated() {
      return request.auth != null;
    }

    // (Opsional tapi disarankan) Mengecek apakah user ada di koleksi "admins"
    // function isAdmin() {
    //   return isAuthenticated() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    // }

    // ==========================================
    // KOLEKSI PUBLIK (Hanya Boleh Baca)
    // ==========================================
    match /settings/{docId}          { allow read: if true; }
    match /berita/{docId}            { allow read: if true; }
    match /wisata/{docId}            { allow read: if true; }
    match /potensi/{docId}           { allow read: if true; }
    match /bumdes/{docId}            { allow read: if true; }
    match /galeri/{docId}            { allow read: if true; }
    match /layanan/{docId}           { allow read: if true; }
    match /perangkat/{docId}         { allow read: if true; }
    match /fasilitas/{docId}         { allow read: if true; }
    match /pengumuman/{docId}        { allow read: if true; }
    match /agenda/{docId}            { allow read: if true; }
    match /survei/{docId}            { allow read: if true; }

    // ==========================================
    // KOLEKSI INPUT PUBLIK
    // ==========================================
    
    // SURVEI: Publik hanya bisa submit, tidak bisa baca
    match /survei_jawaban/{docId} { 
      allow create: if true 
        // Contoh Validasi: Mencegah bot mengirim payload ngawur
        // Pastikan request memiliki field yang wajar (sesuaikan dengan kode Anda)
        && request.resource.data.keys().hasAny(['surveiId', 'jawaban', 'createdAt']);
        
      allow read, update, delete: if false; 
    }

    // ANALYTICS: Publik hanya log visit, admin bisa baca
    match /analytics_visits/{docId} { 
      allow create: if true
        // Batasi ukuran payload, misalnya bot mengirim string path sangat panjang
        && request.resource.data.path is string 
        && request.resource.data.path.size() < 200; 
        
      allow read: if isAuthenticated(); 
      allow update, delete: if false;
    }
    
    match /analytics_daily/{docId} { 
      allow read, write: if isAuthenticated(); 
    }

    // ==========================================
    // ATURAN CATCH-ALL (UNTUK ADMIN)
    // ==========================================
    // Semua manipulasi tulis untuk koleksi lainnya wajib login.
    match /{document=**} {
      // NOTE: Jika website ini BISA didaftar oleh orang biasa (public login),
      // UBAH 'isAuthenticated()' menjadi aturan pengecekan Admin khusus agar user biasa
      // tidak bisa mengedit konten desa.
      allow read, write: if isAuthenticated();
    }
  }
}
